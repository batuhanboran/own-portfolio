---
import certifications from '../../collections/certifications.json';
---

<section id="certifications" class="py-16 md:py-24">
    <div class="container">
        <div class="text-center">
            <h2 class="text-3xl md:text-4xl font-bold font-brand">Certifications</h2>
            <p class="mt-4 text-lg text-neutral-500 dark:text-neutral-400">
                My professional certifications and qualifications.
            </p>
        </div>

        <div class="grid grid-cols-2 md:grid-cols-4 gap-8 mt-12">
            {certifications.map(cert => (
                <div class="flex flex-col items-center text-center p-6 border border-neutral-200 dark:border-neutral-800 rounded-2xl bg-white/50 dark:bg-neutral-900/50" data-aos="fade-up">
                    <img src={cert.logo} alt={`${cert.name} logo`} class="h-16 w-16 mb-4 object-contain" />
                    <h3 class="font-semibold text-neutral-800 dark:text-neutral-200">{cert.name}</h3>
                </div>
            ))}
        </div>
    </div>
</section>